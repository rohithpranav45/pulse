# PULSE .gitignore — minimal by design (2026-06-19).
#
# Policy: ONLY the 4.6 GB /Data lake and secrets (.env) are excluded — copy those
# to a new machine directly. Plus regenerable dev tooling that is rebuilt by a
# single standard command (node_modules -> `npm install`, __pycache__ -> Python).
# EVERYTHING ELSE the project needs (model pkls, reports, pulse_cache.db, fetch
# caches, parquets) IS versioned, so a fresh desk runs after:
#     git pull  ->  copy /Data + .env  ->  (cd frontend && npm install)
# Nothing else to hunt for.

# -- Excluded by design — copied to the new desk manually ----------------------
/Data/
.env
.env.*
!.env.example
/env

# -- Regenerable dev tooling (one command rebuilds these — never committed) -----
node_modules/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
venv/
.venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
.tox/

# -- Transient runtime output (logs + SQLite WAL sidecars) ----------------------
*.log
*.log.*
backend/_applog.*
backend/db/*.db-journal
backend/db/*.db-wal
backend/db/*.db-shm

# -- OS / editor / local settings ----------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
.claude/settings.local.json
.ipynb_checkpoints/
cloudflared.exe
