# PULSE — Environment Variables
# Copy this file to .env and fill in your values.
# All keys are optional; the dashboard degrades gracefully without them.

# ── News scraping ─────────────────────────────────────────────────────────────
# Free tier available at https://apify.com
APIFY_API_TOKEN=your_apify_api_token_here

# ── FRED macro data ───────────────────────────────────────────────────────────
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Powers /api/macro: DGS10, DCOILWTICO, CPIAUCSL, DEXUSEU
FRED_API_KEY=your_fred_api_key_here

# ── EIA inventory data ────────────────────────────────────────────────────────
# Free key at https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_api_key_here

# ── BLS labor statistics (optional) ──────────────────────────────────────────
# Free key at https://www.bls.gov/developers/
BLS_API_KEY=your_bls_api_key_here

# ── Observability (Sprint 0b) ────────────────────────────────────────────────
# Sentry — error tracking. https://sentry.io/signup/ → create Flask project → DSN
# Same DSN works for both backend (Flask) and frontend (React).
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project>
SENTRY_ENV=local
SENTRY_TRACES_SAMPLE_RATE=0.05
# Vite-exposed mirror of SENTRY_DSN so the React app can init the SDK.
# Sentry DSNs are public by design — safe to ship to the browser.
VITE_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project>
VITE_SENTRY_ENV=local

# Better Stack Logs — log aggregation. https://betterstack.com/logs → create
# Python source → copy "Source token".
BETTER_STACK_TOKEN=your_better_stack_source_token
BETTER_STACK_HOST=in.logs.betterstack.com

# ── Phase 2.5 / 2.6 / 2.7 regime engine mode flags (opt-in) ─────────────────
# Unset = Sprint 3 default (composite 27-cell regime grid, no gating, no sizing).
# PULSE_REGIME_MODE = pooled → 3-cell curve-axis grid (un-gated)
# PULSE_GATED_BLEND = 1      → Phase 2.6 production rule: regime engine fires only
#                              on (regime_pooled='BACK') AND (winner ∈ {Lasso,Huber})
#                              AND (|z| ≥ 0.5σ); else 252d rolling-z baseline.
#                              Forces pooled inference internally.
# PULSE_GATED_SIZE  = full|half|kelly  Phase 2.7 sizing of the regime leg only
#                              (baseline leg always 1.0). Only takes effect when
#                              PULSE_GATED_BLEND=1. full=no sizing (default);
#                              half=0.5× notional; kelly=per-spread Kelly fraction
#                              read from sized_blend_summary.kelly_per_spread_latest
#                              in walkforward_report.json.
# PULSE_REGIME_MODE=pooled
# PULSE_GATED_BLEND=1
# PULSE_GATED_SIZE=half
